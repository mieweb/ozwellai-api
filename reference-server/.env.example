# Server configuration
PORT=3000

# ============================================
# BACKEND CONFIGURATION
# ============================================
# The server auto-detects which backend to use:
#   1. LLM Backend     — if LLM_BASE_URL is set
#   2. Ollama          — if reachable at OLLAMA_BASE_URL
#   3. Mock responses  — fallback when nothing else is available

# ============================================
# LLM BACKEND (primary)
# ============================================
# Works with any OpenAI-compatible API: OpenAI, Portkey Gateway, etc.
# Just set the base URL and API key for your provider.
#
# IMPORTANT: Use only the base URL (scheme + host + optional port).
# Do NOT include /v1 or any endpoint path.
#
# OpenAI:
#   LLM_BASE_URL=https://api.openai.com
#   LLM_API_KEY=sk-...
#   LLM_MODEL=gpt-4.1-mini        # Fallback model — used when an agent's configured model doesn't exist on this provider
#
# Portkey Gateway (routes to OpenAI, Anthropic, Ollama — provider keys stored server-side):
#   LLM_BASE_URL=https://gateway-api.os.mieweb.org
#   LLM_API_KEY=<your-gateway-key>
#   LLM_PROVIDER=openai          # or: anthropic, ollama
#   LLM_MODEL=gpt-4.1-mini       # Fallback model — used when an agent's configured model doesn't exist on this provider
#
# Contact adamerla128@gmail.com for a gateway API key.
#
# LLM_PROVIDER is only needed for Portkey (sent as x-portkey-provider header).
#
# NOTE: Only OpenAI-compatible APIs work here. To use Anthropic models,
# route through a Portkey Gateway (which translates the protocol).
#
# THINKING/REASONING BUBBLES:
# The chat widget can display "thinking" bubbles for models that expose reasoning.
# Currently only Ollama models (e.g. qwen, gpt-oss) produce visible thinking
# via <think> tags — no special config needed, it works automatically.
# OpenAI and Anthropic models do NOT expose thinking tokens in their API responses.
# If your provider doesn't support visible thinking, set thinkingEnabled: false
# in the widget config to hide the reasoning UI toggle.

# ============================================
# OLLAMA (fallback)
# ============================================
# Direct connection to an Ollama instance (local or remote).
# Used as fallback when LLM_BASE_URL is not set.
# If both LLM_BASE_URL and OLLAMA_BASE_URL are set, LLM takes priority.
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:latest
#
# If OLLAMA_MODEL is not set, the server auto-detects from available models.
# Common models: llama3.2:latest, llama3.1:latest, mistral:latest, qwen2.5-coder:3b

# ============================================
# FALLBACK
# ============================================
# Model name used in mock responses when no backend is available.
# DEFAULT_MODEL=gpt-4o-mini
