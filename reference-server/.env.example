# Server configuration
PORT=3000

# ============================================
# OLLAMA CONFIGURATION
# ============================================
# For local Ollama:
OLLAMA_BASE_URL=http://localhost:11434
# For remote Ollama container:
# OLLAMA_BASE_URL=https://your-ollama-host.example.com

# ============================================
# PORTKEY GATEWAY CONFIGURATION
# ============================================
# Gateway URL (Portkey AI Gateway as LLM backend)
# When configured, gateway is used as the primary backend (over Ollama)
# PORTKEY_GATEWAY_URL=https://your-gateway-host.example.com
# API key for authenticating with the gateway
# PORTKEY_GATEWAY_API_KEY=your-gateway-api-key
# Provider to use via the gateway (openai, anthropic, ollama)
# PORTKEY_PROVIDER=openai
# Default model when using the gateway
# PORTKEY_MODEL=gpt-4o-mini

# ============================================
# FOR OPENAI TESTING (see landing-page/OPENAI_TESTING.md)
# ============================================
# EMBED_CHAT_BASE_URL=https://api.openai.com/v1
# EMBED_CHAT_API_KEY=sk-proj-YOUR_KEY_HERE
# EMBED_CHAT_MODEL=gpt-4o-mini
