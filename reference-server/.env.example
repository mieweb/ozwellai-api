# Server configuration
PORT=3000

# ============================================
# BACKEND CONFIGURATION
# ============================================
# The server auto-detects which backend to use:
#   1. Portkey Gateway  — if PORTKEY_GATEWAY_URL is set
#   2. Ollama           — if reachable at OLLAMA_BASE_URL
#   3. Mock responses   — fallback when nothing else is available
#
# Clients can force Ollama by sending Authorization: Bearer ollama.

# ============================================
# PORTKEY GATEWAY
# ============================================
# When configured, the gateway is the primary backend.
# It routes requests to the provider set by PORTKEY_PROVIDER.
# IMPORTANT: Use only the base URL (scheme + host + optional port).
# Do NOT include /v1 or any endpoint path.
# PORTKEY_GATEWAY_URL=https://gateway-api.os.mieweb.org
# PORTKEY_GATEWAY_API_KEY=<contact adamerla128@gmail.com for an API key>
# PORTKEY_PROVIDER=openai
# PORTKEY_MODEL=gpt-4o-mini
#
# Provider and model examples:
#   openai:    gpt-4o, gpt-4o-mini, gpt-4-turbo
#   anthropic: claude-sonnet-4-20250514, claude-haiku-4-5-20251001
#   ollama:    llama3.2, llama3.1, mistral

# ============================================
# OLLAMA
# ============================================
# Direct connection to an Ollama instance (local or remote).
# Used as fallback when no gateway is configured.
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:latest
#
# If OLLAMA_MODEL is not set, the server auto-detects from available models.
# Common models: llama3.2:latest, llama3.1:latest, mistral:latest, qwen2.5-coder:3b

# ============================================
# FALLBACK
# ============================================
# Model name used in mock responses when no backend is available.
# DEFAULT_MODEL=gpt-4o-mini
