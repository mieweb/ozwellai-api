# Landing Page Environment Variables
# Copy this file to .env and fill in your values

# Reference server URL (where the Ozwell API runs)
REFERENCE_SERVER_URL=http://localhost:3000

# Agent keys (optional — created via Agent Dashboard or POST /v1/agents)
# When set, these are injected into the HTML pages at serve time.
# When empty, the pages work without agent mode (no server-side prompt).
LANDING_AGENT_KEY=
TICTACTOE_AGENT_KEY=
